# Copy to ".env" and fill in. These are read at BUILD time by Vite.
# After changing them you must rebuild (npm run build) / redeploy.

# Google Apps Script web-app URL that backs the booking database.
# Leave blank to run in local-demo mode (data stays in the browser only).
VITE_SHEETS_ENDPOINT=

# Staff passcode for the /admin panel. MUST exactly match the TOKEN constant
# inside google-apps-script/Code.gs. Change this to something private.
VITE_ADMIN_PASSCODE=recharge2026
