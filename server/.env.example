# Backend API config. Copy to ".env" (gitignored) and fill in.

# Postgres connection. Created by docs/ADMIN_SETUP.md step.
DATABASE_URL=postgresql://recharge_app:CHANGE_ME@127.0.0.1:5432/recharge_rehab

# Staff passcode. MUST equal VITE_ADMIN_PASSCODE on the website.
ADMIN_TOKEN=recharge2026

# Port the unified server listens on (serves the site + /api).
# Production: 3000. For local dev (Vite on 3000), run the API on e.g. 4000.
PORT=3000
